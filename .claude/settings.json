{
  "model": "claude-sonnet-4-6",
  "autoMemoryEnabled": true,
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx tsc *)",
      "Bash(npx eslint *)",
      "Bash(npx prettier *)",
      "Bash(npx supabase *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(gh issue *)",
      "Bash(gh pr *)",
      "Bash(vercel env *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push origin main *)",
      "Bash(vercel --prod *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "command": "/Users/yantr/.local/bin/code-review-graph update --quiet --skip-flows",
        "timeout": 5000
      }
    ],
    "SessionStart": [
      {
        "command": "/Users/yantr/.local/bin/code-review-graph status --json",
        "timeout": 3000
      }
    ],
    "PreCommit": [
      {
        "command": "/Users/yantr/.local/bin/code-review-graph detect-changes --brief",
        "timeout": 10000
      },
      {
        "command": "/Users/yantr/Desktop/Kaelus.Online-main/.claude/hooks/pre-commit.sh",
        "timeout": 60000
      }
    ]
  }
}
