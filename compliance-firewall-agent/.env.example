# ===== KAELUS AI COMPLIANCE FIREWALL =====
# Copy this file to .env.local and fill in your values
# The app works in DEMO MODE without any config!

# ====================================
# SUPABASE (Optional - for production)
# ====================================
# Get these from: supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ====================================
# ENCRYPTION (Auto-generated)
# ====================================
# 256-bit hex key for AES-256 quarantine encryption
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# ====================================
# NOTIFICATIONS (Optional)
# ====================================
# Slack webhook for real-time alerts
SLACK_WEBHOOK_URL=

# ====================================
# AI CLASSIFICATION (Optional - Free)
# ====================================
# Bytez.com free tier - AI-powered zero-shot classification
# Get key at: https://bytez.com/api
BYTEZ_API_KEY=

# ====================================
# APP CONFIG
# ====================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
