# ===== KAELUS AI COMPLIANCE FIREWALL =====
# Copy this file to .env.local and fill in your values
# The app works in DEMO MODE without any config!

# ====================================
# SUPABASE (Optional - for production)
# ====================================
# Get these from: supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ====================================
# ENCRYPTION (Auto-generated)
# ====================================
# 256-bit hex key for AES-256 quarantine encryption
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# ====================================
# NOTIFICATIONS (Optional)
# ====================================
# Slack webhook for real-time alerts
SLACK_WEBHOOK_URL=

# ====================================
# AI CLASSIFICATION (Optional - Free)
# ====================================
# Bytez.com free tier - AI-powered zero-shot classification
# Get key at: https://bytez.com/api
BYTEZ_API_KEY=

# ====================================
# STRIPE (Optional - for payments)
# ====================================
# Get from: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Create products in Stripe, then paste Price IDs here
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=
STRIPE_ENTERPRISE_ANNUAL_PRICE_ID=
STRIPE_AGENCY_MONTHLY_PRICE_ID=
STRIPE_AGENCY_ANNUAL_PRICE_ID=

# ====================================
# OPENROUTER (Optional - for AI chat)
# ====================================
# Get from: openrouter.ai/keys
OPENROUTER_API_KEY=

# ====================================
# POSTHOG (Optional - for analytics)
# ====================================
# Get from: posthog.com → Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ====================================
# APP CONFIG
# ====================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
