# ─── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=REPLACE_WITH_YOUR_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_WITH_YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_YOUR_SUPABASE_SERVICE_ROLE_KEY

# ─── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=REPLACE_WITH_YOUR_STRIPE_SECRET
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_YOUR_STRIPE_WEBHOOK_SECRET
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
STRIPE_GROWTH_MONTHLY_PRICE_ID=price_...
STRIPE_GROWTH_ANNUAL_PRICE_ID=price_...
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=price_...
STRIPE_ENTERPRISE_ANNUAL_PRICE_ID=price_...
STRIPE_AGENCY_MONTHLY_PRICE_ID=price_...
STRIPE_AGENCY_ANNUAL_PRICE_ID=price_...

# ─── AI / LLM ─────────────────────────────────────────────
OPENROUTER_API_KEY=REPLACE_WITH_YOUR_OPENROUTER_API_KEY
# Required for Claude Dreams (Managed Agents research preview)
ANTHROPIC_API_KEY=REPLACE_WITH_YOUR_ANTHROPIC_API_KEY

# ─── Brain / Ingest ────────────────────────────────────────
# Protects POST /api/brain/ingest and POST /api/brain/dreams
# when Supabase is not configured (local dev / demo mode).
# Generate: openssl rand -hex 32
INGEST_API_KEY=REPLACE_WITH_RANDOM_64_CHAR_HEX

# ─── Email (Resend) ───────────────────────────────────────
RESEND_API_KEY=REPLACE_WITH_YOUR_RESEND_API_KEY

# ─── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://houndshield.com
ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_HEX_STRING

# ─── Missing from previous version (now required) ─────────────────
STRIPE_SOLO_MONTHLY_PRICE_ID=price_...
STRIPE_SOLO_ANNUAL_PRICE_ID=price_...
ANTHROPIC_API_KEY=REPLACE_WITH_YOUR_ANTHROPIC_KEY
NEXT_PUBLIC_POSTHOG_KEY=REPLACE_WITH_YOUR_POSTHOG_KEY
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
