# Kaelus Proxy — environment variables
# Copy to .env and fill in your values

# Required: your Kaelus license key (from https://kaelus.online/dashboard)
KAELUS_LICENSE_KEY=kls_xxxxxxxxxxxxxxxxxxxxxxxx

# Required: your AI provider API key (never stored, only used to forward requests)
UPSTREAM_API_KEY=YOUR_OPENAI_OR_ANTHROPIC_KEY_HERE

# Optional: openai | anthropic | google | openrouter  (default: openai)
UPSTREAM_PROVIDER=openai

# Optional: port to listen on (default: 8080)
PORT=8080

# Optional: directory for local SQLite event log (default: ./data)
KAELUS_DATA_DIR=./data

# Optional: override kaelus.online API URL (for testing)
# KAELUS_API_URL=https://kaelus.online/api
